{
  "name": "anicore",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@api-wrappers/anilist-wrapper": "^2.7.0",
      "@api-wrappers/tmdb-wrapper": "^2.2.0",
      "@elysia/cors": "^1.3.3",
      "@radix-ui/react-slot": "^1.1.1",
      "@tailwindcss/vite": "^4.1.11",
      "@types/react": "^19.0.0",
      "@types/react-dom": "^19.0.0",
      "@vitejs/plugin-react": "^4.6.0",
      "class-variance-authority": "^0.7.1",
      "clsx": "^2.1.1",
      "drizzle-kit": "latest",
      "drizzle-orm": "latest",
      "elysia": "latest",
      "lucide-react": "^0.468.0",
      "postgres": "^3.4.5",
      "react": "^19.0.0",
      "react-dom": "^19.0.0",
      "tailwind-merge": "^2.6.0",
      "tailwindcss": "^4.1.11",
      "bun-types": "latest",
      "typescript": "latest",
      "vite": "^6.0.0"
    }
  },
  "scripts": {
    "dev": "turbo run dev --ui=stream",
    "dev:api": "turbo run dev --filter=@anicore/api --ui=stream",
    "dev:web": "turbo run dev --filter=@anicore/web --ui=stream",
    "start": "turbo run start --ui=stream",
    "build": "turbo run build --ui=stream",
    "typecheck": "turbo run typecheck --ui=stream",
    "test": "turbo run test --ui=stream",
    "db:generate": "turbo run db:generate --filter=@anicore/api --ui=stream",
    "db:migrate": "turbo run db:migrate --filter=@anicore/api --ui=stream",
    "db:push": "turbo run db:push --filter=@anicore/api --ui=stream",
    "db:studio": "turbo run db:studio --filter=@anicore/api --ui=stream",
    "db:check-shape": "turbo run db:check-shape --filter=@anicore/api --ui=stream",
    "db:seed": "turbo run db:seed --filter=@anicore/api --ui=stream",
    "db:empty": "turbo run db:empty --filter=@anicore/api --ui=stream",
    "sync": "turbo run sync --filter=@anicore/api --ui=stream --",
    "sync:dry": "turbo run sync:dry --filter=@anicore/api --ui=stream --",
    "sync:anilist": "turbo run sync:anilist --filter=@anicore/api --ui=stream --",
    "sync:audio": "turbo run sync:audio --filter=@anicore/api --ui=stream --"
  },
  "devDependencies": {
    "bun-types": "^1.3.14",
    "turbo": "^2.10.4",
    "typescript": "^7.0.2"
  }
}
