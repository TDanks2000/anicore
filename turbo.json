{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "ANICORE_*",
    "DATABASE_URL",
    "PORT",
    "HOST",
    "CORS_ORIGIN",
    "TMDB_API_KEY",
    "TVDB_API_KEY",
    "TVDB_PIN",
    "VITE_*"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "cache": false,
      "persistent": true
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "db:push": {
      "cache": false
    },
    "db:studio": {
      "cache": false,
      "persistent": true
    },
    "db:check-shape": {
      "cache": false
    },
    "db:seed": {
      "cache": false
    },
    "db:empty": {
      "cache": false
    },
    "sync": {
      "cache": false
    },
    "sync:dry": {
      "cache": false
    },
    "sync:anilist": {
      "cache": false
    },
    "sync:audio": {
      "cache": false
    }
  }
}
