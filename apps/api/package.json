{
  "name": "@anicore/api",
  "version": "0.1.0",
  "scripts": {
    "build": "tsc --noEmit",
    "db:check-shape": "bun src/scripts/check-db-shape.ts",
    "db:empty": "bun src/scripts/empty-db.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "bun src/scripts/seed.ts",
    "db:studio": "drizzle-kit studio",
    "dev": "bun --cwd ../.. --watch --preload ./scripts/api-cwd.ts apps/api/src/index.ts",
    "start": "bun src/index.ts",
    "sync": "bun src/scripts/sync.ts",
    "sync:anilist": "bun src/scripts/sync-anilist.ts",
    "sync:audio": "bun src/scripts/sync-audio-status.ts",
    "sync:dry": "bun src/scripts/sync.ts --dry-run",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "private": true,
  "type": "module",
  "dependencies": {
    "@anicore/db": "workspace:*",
    "@anicore/providers": "workspace:*",
    "@anicore/sync-monitor": "workspace:*",
    "@api-wrappers/anilist-wrapper": "catalog:",
    "@api-wrappers/tmdb-wrapper": "catalog:",
    "@elysia/cors": "catalog:",
    "drizzle-orm": "catalog:",
    "elysia": "catalog:",
    "postgres": "catalog:"
  },
  "devDependencies": {
    "bun-types": "catalog:",
    "drizzle-kit": "catalog:",
    "typescript": "catalog:"
  }
}
